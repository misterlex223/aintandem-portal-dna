# frpc Client Configuration
# Generated by install.sh - DO NOT edit manually

# Server connection
serverAddr = {{SERVER_ADDR}}
serverPort = {{SERVER_PORT}}
auth.token = {{AUTH_TOKEN}}

# Client name
user = {{CLIENT_NAME}}

# HTTP proxy configuration
[[proxies]]
name = "{{PROXY_NAME}}"
type = "http"
localIP = {{LOCAL_IP}}
localPort = {{LOCAL_PORT}}
subdomain = {{SUBDOMAIN}}

# Health check
healthCheckType = "tcp"
healthCheckIntervalS = 30
healthCheckMaxFailed = 3
